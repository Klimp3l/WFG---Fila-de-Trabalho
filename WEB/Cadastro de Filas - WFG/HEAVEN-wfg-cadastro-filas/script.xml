<link rel="stylesheet" href="https://use.fontawesome.com/releases/v7.0.0/css/all.css" crossorigin="anonymous">

<!--section-->

<div id="app" class="wfg-app">
<!--	<aside class="wfg-sidebar">-->
<!--		<div class="wfg-brand">-->
<!--			<span class="wfg-brand-dot"></span>-->
<!--			<span>WFG Studio</span>-->
<!--		</div>-->

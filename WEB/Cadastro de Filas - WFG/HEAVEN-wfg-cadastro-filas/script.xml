	<section class="wfg-main" id="vueTable">
		<div class="wfg-topbar">
			<div class="wfg-title">
				<h1>Cadastro de Filas WFG</h1>
			</div>
			<div class="wfg-actions">
				<button class="wfg-btn primary" @click="openInsert">
					<i class="el-icon-fa-plus"></i><span> Incluir</span>
				</button>
			</div>
		</div>

		<el-card shadow="never" class="box-card el-cst-crud-card wfg-surface">
			<el-form ref="formFilter" :model="filterModel" :inline="true" size="medium" class="demo-form-inline"
				@submit.native.prevent>
				<el-row :gutter="14">
					<el-col :xs="24" :sm="24" :md="10" :lg="10" :xl="10">
						<el-form-item label="Descrição">
							<el-input ref="filter_descricao" v-model="filterModel.descricao"
								placeholder="Pesquisar pela descrição da fila"
								@keyup.enter.native="filter(true)"></el-input>
						</el-form-item>
					</el-col>
					<el-col :xs="24" :sm="24" :md="4" :lg="4" :xl="4">
						<el-form-item label="ID">
							<el-input v-model="filterModel.id" placeholder="ID da fila"
								@keyup.enter.native="filter(true)"></el-input>
						</el-form-item>
					</el-col>
					<el-col :xs="24" :sm="24" :md="4" :lg="4" :xl="4">
						<el-form-item label="Situação">
							<el-select v-model="filterModel.situacao">
								<el-option label="Ativo" value="A"></el-option>
								<el-option label="Inativo" value="I"></el-option>
								<el-option label="Todas" value=""></el-option>
							</el-select>
						</el-form-item>
					</el-col>
					<el-col :xs="24" :sm="24" :md="6" :lg="6" :xl="6">
						<div class="wfg-filter-actions">
							<el-form-item><br>
								<button class="wfg-btn primary" @click="filter">
									<i class="el-icon-fa-filter"></i><span> Filtrar</span>
								</button>
								<button class="wfg-btn warning" @click="reset()">
									<i class="el-icon-fa-eraser"></i><span> Limpar</span>
								</button>
							</el-form-item>
						</div>
					</el-col>
				</el-row>
			</el-form>

			<el-search-table-pagination ref="table" :fetch="fetch" @sort-change="onSortChange"
				@current-change="onCurrentChange" :stripe=false :border=false :highlight-current-row=true row-key="id"
				list-field="list" total-field="total" :page-sizes="[5,10,25,50,100]" :params="filterModel"
				:columns="$options.columns">
				<template slot-scope="scope" slot="rowIndex">
					{{ scope.$index }}
				</template>
				<template slot-scope="scope" slot="ativo">
					<el-switch v-model="scope.row.situacao" :active-value="'A'" :disabled="true"></el-switch>
				</template>
			</el-search-table-pagination>
		</el-card>

		<div class="wfg-topbar">
			<div class="wfg-title">
				<h1 v-if="selectedRow && selectedRow.id">Fila: <strong>{{ selectedRow.descricao }}</strong></h1>
				<p v-else><strong>Selecione uma fila para visualizar os detalhes</strong></p>
			</div>
			<div class="wfg-actions">
				<button v-if="selectedRow && selectedRow.id" class="wfg-btn success" @click="openEdit">
					<i class="el-icon-fa-edit"></i><span> Editar</span>
				</button>
				<button v-if="selectedRow && selectedRow.id" class="wfg-btn warning" @click="openCopy">
					<i class="el-icon-fa-copy"></i><span> Copiar</span>
				</button>
			</div>
		</div>

		<section class="wfg-kpis" v-show="selectedRow && selectedRow.id">
			<article class="wfg-kpi"><span>Total de Nós</span><strong>{{ nodeCountSelected }}</strong></article>
			<article class="wfg-kpi"><span>Execuções 24h</span><strong>0</strong></article>
			<article class="wfg-kpi"><span>Falhas 24h</span><strong>0</strong></article>
		</section>

		<div class="wfg-canvas-with-panel" v-show="selectedRow && selectedRow.id">
		
		<section class="wfg-canvas-wrap">
			<div class="wfg-canvas-header">
				<span>Fluxo de tarefas da fila</span>
				<div class="wfg-canvas-actions">
					<span>Status: <strong :class="flowStatusClass">{{ flowStatusText }}</strong></span>
					<button class="wfg-btn success" @click="saveFlow" :disabled="!flowIsValid">
						<i class="el-icon-fa-save"></i><span> Salvar fluxo</span>
					</button>
					<button class="wfg-btn primary" @click="openAddNodeDialog">
						<i class="el-icon-fa-plus"></i><span> Adicionar nó</span>
					</button>
				</div>
			</div>
			<div class="wfg-canvas-placeholder" v-if="drawflowError">
				<span>{{ drawflowError }}</span>
			</div>
			<div class="wfg-drawflow-editor-wrap" v-show="!drawflowError">
				<div id="drawflowEditor" class="wfg-drawflow-editor"></div>
				<div class="wfg-drawflow-bar-zoom" role="group" aria-label="Controles de zoom do fluxo">
					<button type="button" class="wfg-drawflow-zoom-btn" @click="zoomOutDrawflow" title="Diminuir zoom">
						<i class="fa-solid fa-magnifying-glass-minus"></i>
					</button>
					<button type="button" class="wfg-drawflow-zoom-btn wfg-drawflow-zoom-label" @click="zoomResetDrawflow" title="Resetar zoom para 100%">
						{{ drawflowZoomLabel }}
					</button>
					<button type="button" class="wfg-drawflow-zoom-btn" @click="zoomInDrawflow" title="Aumentar zoom">
						<i class="fa-solid fa-magnifying-glass-plus"></i>
					</button>
				</div>
			</div>
			<!-- <div id="drawflow"></div> -->
		</section>

		<aside class="wfg-panel">
			<section class="wfg-side-block">
				<h3>Nó selecionado</h3>
				<p v-if="!selectedDrawflowNodeId" class="wfg-side-hint">Clique em um nó no fluxo para ver metadados e filtros.</p>
				<template v-else>
					<div class="wfg-tag-list">
						<span class="wfg-tag ok">ID: {{ selectedDrawflowNodeId }}</span>
						<span v-if="sidePanelTask" class="wfg-tag">{{ sidePanelTask.nome }}</span>
						<span v-if="sidePanelTask" class="wfg-tag">{{ sidePanelTask.apelido }}</span>
					</div>
					<wfg-node-filters-panel
						:task="sidePanelTask"
						:values="sidePanelValues"
						:resolve-options="resolveFilterOptions"
						@change="syncSidePanelToStore"
					></wfg-node-filters-panel>
				</template>
			</section>
		</aside>
		</div>

		<el-dialog title="Adicionar nó ao fluxo" :visible.sync="dialogNodeVisible" width="560px" :close-on-click-modal="false">
			<el-form label-position="top" size="medium">
				<el-form-item label="Tarefa disponível">
					<el-select v-model="newNodeTaskAlias" filterable style="width: 100%;" placeholder="Selecione uma tarefa">
						<el-option v-for="item in addNodeTaskOptions" :key="item.apelido" :label="item.nome" :value="item.apelido"></el-option>
					</el-select>
				</el-form-item>
			</el-form>
			<span slot="footer" class="dialog-footer">
				<button class="wfg-btn warning" @click="dialogNodeVisible = false">Cancelar</button>
				<button class="wfg-btn primary" @click="confirmAddNode"><i class="el-icon-fa-plus"></i><span> Adicionar</span></button>
			</span>
		</el-dialog>

	</section>

	<div id="vueFormEdit">
		<el-dialog :title="editFormTitle" :visible.sync="dialogVisible" width="70%" :close-on-click-modal="false"
			v-loading="loading">
			<el-form ref="formEdit" :model="editModel" :rules="rules" label-position="top" size="medium"
				class="demo-edit">
				<el-row>
					<el-col :span="24">
						<h3 style="margin: 0;">Código: {{ editModel.id }}</h3>
					</el-col>
				</el-row>
				<el-row :gutter="10">
					<el-col :span="20">
						<el-form-item label="Descrição da Fila" prop="descricao">
							<el-input ref="edit_descricao" v-model="editModel.descricao"></el-input>
						</el-form-item>
					</el-col>
					<el-col :span="4">
						<el-form-item label="Situação" prop="situacao">
							<el-switch :active-value="'A'" :inactive-value="'I'"
								v-model="editModel.situacao"></el-switch>
						</el-form-item>
					</el-col>
				</el-row>
				<el-row :gutter="10">
					<el-col :span="12">
						<el-form-item label="Processo WF" prop="idwfprocesso">
							<el-select v-model="editModel.idwfprocesso" filterable style="width: 100%;" :loading="$$store.loadingProcessos" @change="onChangeProcesso">
								<el-option v-for="item in $$store.optionsProcessos" :key="item.value" :label="item.label"
									:value="item.value">
								</el-option>
							</el-select>
						</el-form-item>
					</el-col>
					<el-col :span="12">
						<el-form-item label="Evento WF" prop="idwfprocessoevento">
							<el-select v-model="editModel.idwfprocessoevento" style="width: 100%;" :loading="$$store.loadingEventos">
								<el-option v-for="item in $$store.optionsEventos" :key="item.value" :label="item.label"
									:value="item.value">
								</el-option>
							</el-select>
						</el-form-item>
					</el-col>
				</el-row>

				<h3 style="margin: 16px 0 8px;">Agenda da tarefa de execução</h3>
				<el-collapse v-model="collapseAgendaNames" style="max-height: 440px; overflow-y: auto; overflow-x: hidden">
					<el-cst-panel title="Dias" style="margin-right: 10px;">
						<el-form-item label-width="0px">
							<el-radio-group v-model="editModel.tipoDias">
								<el-radio :label="0">Executar nos seguintes dias da semana</el-radio>
								<el-radio :label="1">Executar nos seguintes dias</el-radio>
							</el-radio-group>
						</el-form-item>
						<el-form-item v-show="editModel.tipoDias === 0">
							<el-row :gutter="20">
								<el-col :xs="12" :sm="12" :md="8" :lg="3" :xl="3">
									<el-checkbox true-label="1" false-label="0" v-model="editModel._diasSemana[0]">Domingo</el-checkbox>
								</el-col>
								<el-col :xs="12" :sm="12" :md="8" :lg="3" :xl="3">
									<el-checkbox true-label="1" false-label="0" v-model="editModel._diasSemana[1]">Segunda</el-checkbox>
								</el-col>
								<el-col :xs="12" :sm="12" :md="8" :lg="3" :xl="3">
									<el-checkbox true-label="1" false-label="0" v-model="editModel._diasSemana[2]">Terça</el-checkbox>
								</el-col>
								<el-col :xs="12" :sm="12" :md="8" :lg="3" :xl="3">
									<el-checkbox true-label="1" false-label="0" v-model="editModel._diasSemana[3]">Quarta</el-checkbox>
								</el-col>
								<el-col :xs="12" :sm="12" :md="8" :lg="3" :xl="3">
									<el-checkbox true-label="1" false-label="0" v-model="editModel._diasSemana[4]">Quinta</el-checkbox>
								</el-col>
								<el-col :xs="12" :sm="12" :md="8" :lg="3" :xl="3">
									<el-checkbox true-label="1" false-label="0" v-model="editModel._diasSemana[5]">Sexta</el-checkbox>
								</el-col>
								<el-col :xs="12" :sm="12" :md="8" :lg="3" :xl="3">
									<el-checkbox true-label="1" false-label="0" v-model="editModel._diasSemana[6]">Sábado</el-checkbox>
								</el-col>
							</el-row>
						</el-form-item>
						<el-form-item v-show="editModel.tipoDias === 1">
							<el-row :gutter="20">
								<el-col :xs="24" :sm="24" :md="12" :lg="8" :xl="8">
									<el-form-item label="Dias">
										<el-input v-model="editModel.dias" :readonly="true" :clearable="true">
											<el-button type="success" @click="dialogDiasVisible = true" plain slot="prepend">Dias</el-button>
										</el-input>
									</el-form-item>
								</el-col>
								<el-col :xs="24" :sm="24" :md="12" :lg="8" :xl="8">
									<el-form-item label="Meses">
										<el-input v-model="editModel.meses" :readonly="true" :clearable="true">
									  		<el-button type="success" @click="dialogMesesVisible = true" plain slot="prepend">Meses</el-button>
										</el-input>
									</el-form-item>
								</el-col>
								<el-col :xs="24" :sm="24" :md="12" :lg="8" :xl="8">
									<el-form-item label="Anos">
										<el-input v-model="editModel.anos" :readonly="true" :clearable="true">
									  		<el-button type="success" @click="dialogAnosVisible = true" plain slot="prepend">Anos</el-button>
										</el-input>
									</el-form-item>
								</el-col>
							</el-row>
						</el-form-item>
						<el-form-item label="Além das configurações acima a tarefa deverá ser executada nas seguintes datas" label-width="100%" style="clear: both;"></el-form-item>
						<el-form-item>
							<el-input type="textarea" :rows="2" v-model="editModel.datas" :readonly="true" :clearable="true">
						  		<el-button type="success" @click="dialogDatasVisible = true" plain slot="prepend">Datas</el-button>
						  	</el-input>
						</el-form-item>
					</el-cst-panel>
					<el-cst-panel title="Horas" style="margin-right: 10px;">
						<el-form-item label-width="0px">
							<el-radio-group v-model="editModel.tipoHorarios">
								<el-radio :label="0">Executar a cada</el-radio>
								<el-radio :label="1">Executar nos seguintes horários</el-radio>
							</el-radio-group>
						</el-form-item>
						<el-form-item v-show="editModel.tipoHorarios === 0">
							<el-row :gutter="20">
								<el-col :xs="24" :sm="24" :md="12" :lg="8" :xl="8">
									<el-input-number v-model="editModel.intervalo" controls-position="right" :min="1" style="width: 100%;"></el-input-number>
									<el-select v-model="editModel.tipoIntervalo" style="width:100%; margin-top: 8px;">
										<el-option v-for="item in $$store.tiposIntervalos" :key="item.value" :label="item.label" :value="item.value"></el-option>
									</el-select>
								</el-col>
								<el-col :xs="24" :sm="24" :md="12" :lg="16" :xl="16">
									<span style="vertical-align: middle;">entre</span>
									<el-time-picker v-model="editModel._horaInicialHoraFinal" is-range range-separator="e"
										start-placeholder="Horário inicial" end-placeholder="Horário final"
										style="margin-left: 8px; max-width: 100%; vertical-align: middle;"></el-time-picker>
								</el-col>
							</el-row>
						</el-form-item>
						<el-form-item v-show="editModel.tipoHorarios === 1">
							<el-input v-model="editModel.horarios" :readonly="true" :clearable="true">
						  		<el-button type="success" @click="showDialogHorarios()" plain slot="prepend">Horários</el-button>
							</el-input>
						</el-form-item>
						<el-form-item label="Condição Execução" label-width="140px">
							<el-tooltip placement="top-start">
								<div slot="content">
									<b>&lt;condicao1&gt;, &lt;condicao2&gt;, ...</b><br/>
									Exemplos:<br/>
									e: 1 (a tarefa será executada se ainda não houve uma execução no dia)<br/>
									en: 1 (a tarefa será executada se ainda não houve uma execução com notificação no dia)<br/>
									e: 2 week (a tarefa será executada se ainda não houve 2 execuções na semana)<br/>
									Os seguintes atributos podem ser usados:<br/>
									day (padrão), week, month e year
								</div>
								<el-input v-model="editModel.scriptAcao"></el-input>
							</el-tooltip>
						</el-form-item>
					</el-cst-panel>
				</el-collapse>
			</el-form>
			<span slot="footer" class="dialog-footer">
				<el-button @click="dialogVisible = false">Cancelar</el-button>
				<el-button type="success" @click="save()"><i class="el-icon-fa-save"></i><span>Salvar</span></el-button>
			</span>
		</el-dialog>
	    $> sb.append(dialogDias());
	    $> sb.append(dialogMeses());
	    $> sb.append(dialogAnos());
	    $> sb.append(dialogDatas());
	    $> sb.append(dialogHorarios());
	</div>

</div>


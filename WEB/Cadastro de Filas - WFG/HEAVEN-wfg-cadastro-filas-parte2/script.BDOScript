<script_function name="getPontoExposicao">
	~not_save_exec;
    connect $v{ds_bridge};
	
	sql 
	Select
		p.idpontoexposicao as value
		,p.descricao as label
	From
		pontoexposicao p
	Where 
		p.situacao = 'A'
	Order by
		p.descricao asc
	sql_var(sqlPontoExposicao);

	<!--output-->
	$> msgBuilder.setContentType('application/json');
	$> msgBuilder.setContentEncoding('gzip');
	$> msgBuilder.setCharset('UTF-8');
	$> sb.append('[').append(msgBuilder.sqlVarToJSON('sqlPontoExposicao')).append(']');
</script_function>

<script_function name="getProcessos">
	~not_save_exec;
	connect $v{ds_bridge};

	sql 
	Select
		p.idwfprocesso as value
		,p.descricao||' - '||p.idwfprocesso as label
		,coalesce((
			Select
				json_agg(
					json_build_object(
						'value', pe.idwfprocessoevento,
						'label', pe.descricao||' - '||pe.idwfprocessoevento
					)
				)
			From
				wfprocessoevento pe
			Where
				pe.idwfprocesso = p.idwfprocesso
				and pe.situacao = 'A'
		), '[]') as eventos
	From
		wfprocesso p
	Where
		p.situacao = 'A'
	Order by
		p.descricao asc
	sql_var(sql) sql_props(lower_labels);

	<!--output-->
	$> msgBuilder.setContentType('application/json');
	$> sb.append('[').append(msgBuilder.sqlVarToJSON('sql')).append(']');
</script_function>

<script_function name="getAtividadesRealizadas">
	~not_save_exec;
	connect $v{ds_bridge};

	sql
	Select
		ar.idwfprocesso
		,ar.idwfatividaderealizada as value
		,ar.descricao||' - '||ar.idwfatividaderealizada as label
	From
		wfatividaderealizada ar
		inner join wfatividade a on (a.idwfatividade = ar.idwfatividade)
	Where
		ar.tiposituacao = 'F'
	Order by
		ar.descricao
	sql_var(sql) sql_props(lower_labels);

	<!--output-->
	$> msgBuilder.setContentType('application/json');
	$> sb.append('[').append(msgBuilder.sqlVarToJSON('sql')).append(']');
</script_function>
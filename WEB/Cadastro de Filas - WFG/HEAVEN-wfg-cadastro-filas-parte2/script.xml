<script_content name="dialogDatas">
	<el-dialog title="Selecionar Datas" :visible.sync="dialogDatasVisible" width="30%" @open="dialogDatasOpen()">
		<el-date-picker ref="edit_select_dates" type="dates" v-model="dialogDatas.datas" format="dd/MM/yyyy" value-format="dd/MM/yyyy" @change="dialogDatasOK()" prefix-icon="x" style="width: 100%;">
	</el-dialog>
</script_content>

<script_content name="dialogHorarios">
	<el-dialog title="Selecionar Horários" :visible.sync="dialogHorariosVisible" width="30%">
		<el-form label-width="70px" size="mini" class="demo-edit">
			<el-form-item label="Intervalo">
				<el-input-number v-model="dialogHorarios.intervalo" controls-position="right" :min="1" size="mini" style="width: 100px;"></el-input-number>
				minutos
			</el-form-item>
			<el-form-item label="Entre">
				<el-time-picker v-model="dialogHorarios.horaInicialHoraFinal" is-range range-separator="e" start-placeholder="Horário inicial" end-placeholder="Horário final" size="mini">
				</el-time-picker>
				<el-button type="primary" @click="dialogHorariosRefresh()" plain size="mini"><i class="el-icon-fa-refresh"></i></el-button>
			</el-form-item>
		</el-form>	
		<el-checkbox-group v-model="dialogHorarios.horarios">
    		<el-col :xs="8" :sm="8" :md="8" :lg="8" :xl="8" v-for="horario in dialogHorarios._horarios" :key="horario.desc">
    			<el-checkbox :label="horario.horario">{{horario.desc}}</el-checkbox>
    		</el-col>
  		</el-checkbox-group>
  		<el-row>
		</el-row>
  		<span slot="footer" class="dialog-footer">
	    	<el-button @click="dialogHorariosVisible = false">Cancelar</el-button>
	    	<el-button type="primary" @click="dialogHorariosOK()">OK</el-button>
	  	</span>
	</el-dialog>
</script_content>

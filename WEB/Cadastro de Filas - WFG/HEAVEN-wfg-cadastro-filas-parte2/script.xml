
<script_content name="dialogDias">
	<el-dialog title="Selecionar Dias do Mês" :visible.sync="dialogDiasVisible" width="30%">
		<el-checkbox-group v-model="dialogDias.dias">
    		<el-col :xs="8" :sm="8" :md="8" :lg="8" :xl="8" v-for="dia in $$store.dias" :key="dia.desc">
    			<el-checkbox :label="dia.dia">{{dia.desc}}</el-checkbox>
    		</el-col>
  		</el-checkbox-group>
  		<el-row>
		</el-row>
  		<span slot="footer" class="dialog-footer">
	    	<el-button @click="dialogDiasVisible = false">Cancelar</el-button>
	    	<el-button type="primary" @click="dialogDiasOK()">OK</el-button>
	  	</span>
	</el-dialog>
</script_content>


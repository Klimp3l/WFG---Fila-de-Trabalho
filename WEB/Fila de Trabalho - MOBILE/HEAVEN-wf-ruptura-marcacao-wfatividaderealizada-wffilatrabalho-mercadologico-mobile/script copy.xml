		$(document).ready(function() {
			w2utils.locale("js/w2ui/locale/pt-br.json");
			$.extend($.fn.bootstrapTable.defaults, $.fn.bootstrapTable.locales["pt-BR"]);

			function getTableHeight() {
			    return $(window).height() - 50;
			}	
			$table = $("#data-table").bootstrapTable({
			    data: data,
			    height: getTableHeight(),
			    toolbar: "#custom-toolbar",
			    striped: true,
			    pagination: true,
			    pageSize: 10,
			    pageList: [10, 20, 30, 60, 100, 200],
			    search: true,
			    showColumns: true,
			    showRefresh: false,
			    showToggle: false,
			    minimumCountColumns: 2,
			    clickToSelect: true,
			    locale: "pt-BR",
			    columns: columns
			});

			setTimeout(function() {
				adjustHeaderScrollbarGutter();
			}, 0);

			$table.on(' column-switch.bs.table', function (field, checked) {
				let data = $table.bootstrapTable('getOptions').columns;
				localStorage.setItem(keyCols, JSON.stringify(data));
				adjustHeaderScrollbarGutter();
			});

			$table.on('post-body.bs.table page-change.bs.table search.bs.table', function () {
				adjustHeaderScrollbarGutter();
			});
			
			$(window).resize(function() {
				$table.bootstrapTable("resetView", { height: getTableHeight() });
				adjustHeaderScrollbarGutter();
			});
			
			$(".keep-open > button").addClass("btn-lg");
			$(".search > input").addClass("input-lg");
			
			var $customToolbar = $("#custom-toolbar");
			
			$customToolbar.find(".title").html(wfatividade.descricao);
			
			$('.includeLoader').show();
			syncData().then(r => {
				$('.includeLoader').hide();
				adjustHeaderScrollbarGutter();
				
				let tempData = localStorage.getItem(key);
				if (tempData) {
					console.log('TEM');
					$("#sync-modal").modal('show');
				}
			});
	     });

		function syncData() {
			return new Promise(resolve => {
				let tempData = localStorage.getItem(key);
				if (tempData) {
					tempData = JSON.parse(tempData);
					let data = $table.bootstrapTable('getData');
					for (var i = 0; i < data.length; i++) {
						var row = tempData.filter(index => (index.idwffilatrabalho === data[i].idwffilatrabalho))[0];
						if (row) {
							data[i] = row;
							$table.bootstrapTable('updateRow', {index: i, row: data[i]});
						}
					}
				}
				resolve(true);
			});
		}

		function doSaveTemp() {
			let data = $.grep($table.bootstrapTable("getData"), function(r) { return r.idwfatividaderealizada });
			if(JSON.stringify(data) === '[]'){
				localStorage.removeItem(key);
				return;
			}
			localStorage.setItem(key, JSON.stringify(data));
		}

	    function textRender(value, row, index, fieldName){
	    	if (value == null || value == '') {
	    		return [
					\'<div class="input-group">\',
						\'<input class="render" type="text" class="form-control"\'
						+ \' onchange="NumberLoad(this, \' + index + \', \\\'\' + fieldName + \'\\\')"\'
						+ \' name="\' + fieldName + \'"\'
						+ \'/>\',
					\'</div>\'
		    	].join("");
	    	}
	    	return [
				\'<div class="input-group">\',
					\'<input class="render" type="text" class="form-control"\'
					+ \' onchange="NumberLoad(this, \' + index + \', \\\'\' + fieldName + \'\\\')"\'
					+ \' value="\' + value + \'"\'
					+ \' name="\' + fieldName + \'"\'
					+ \'/>\',
				\'</div>\'
	    	].join("");
	    }  	

		function doSave() {
			$("#sync-modal").modal('hide');
			$('.includeLoader').show();
			var records = $.grep($table.bootstrapTable("getData"), function(r) { return r.idwfatividaderealizada });
			if(JSON.stringify(records) === '[]'){
				$('.includeLoader').hide();
				confirm("Por favor. Selecione uma aÃ§Ã£o antes de salvar."); 
				return false;
			}
		    $.ajax({
		        type: "POST",
		        dataType: "json",
		        url: "odwctrl?action=execTarefa&ajax=true&scriptFunction=update&idTarefa=" + idTarefa,
		        data: { wffilatrabalho: JSON.stringify(records) }, 
		        contentType: "application/x-www-form-urlencoded; charset=ISO-8859-1",
		        success: function(response) {
		        	$('.includeLoader').hide();
					if(showResponse(response)) {
						localStorage.removeItem(key);
						hideRows(getRecids(records).split(","));
					}
		        }
		    });
		}

		function doExport() {
		    $.ajax({
		        type: "POST",
		        dataType: "text",
		        url: "odwctrl?action=execTarefa&ajax=true&scriptFunction=export&idTarefa=" + idTarefa,
		        data: { wffilatrabalho: JSON.stringify($table.bootstrapTable("getData")) }, 
		        contentType: "application/x-www-form-urlencoded; charset=ISO-8859-1",
		        success: function(response) {
		            $("<iframe>", { src: $(response).filter("a").attr("href") })
		            	.hide()
		            	.appendTo($("body"));
		        }
		    });
		}

		function getRecids(records) {
			var recids = "0";
			for(var r in records) {
				recids += "," + records[r].recid;
			}
			return recids;
		}

		function showResponse(response) {
			var error = response.error.length > 0;
			$(".modal-title").html((error ? "<span class=\'glyphicon glyphicon-remove-circle\'></span>" : "<span class=\'glyphicon glyphicon-ok-circle\'></span> ") + response.msg);
			$(".modal-body").html(error ? "<div class=\'alert alert-danger\' role=\'alert\'> " + response.error + "</div>" : "");
			$("#modal").modal("show");
			return !error;
		}

		function hideRows(recids) {
			$table.bootstrapTable("remove", { field: "recid", values: recids });
		}

	    function setDropDown(rowIndex, fieldName, fieldValue) {
			$table.bootstrapTable("updateCell", { rowIndex: rowIndex, fieldName: fieldName, fieldValue: fieldValue });
	    }

		function filterDepartamento(iddepartamento) {		
			filterIdDepartamento = iddepartamento;
			applyFilters();
	    }

		function filterSetor(idsetor) {		
			filterIdSetor = idsetor;
			applyFilters();
	    }

		function filterEstoque() {
			filterEstoqueAtivo = $("#filter-estoque").is(":checked");
			applyFilters();
		}

		function applyFilters() {
			$table.bootstrapTable('load', data);
			
			let par = {};
			
			if (filterIdDepartamento > 0) {
				par.iddepartamento = filterIdDepartamento;
			}
			if (filterIdSetor > 0) {
				par.idsetor = filterIdSetor;
			}
			
			if (Object.keys(par).length > 0) {
				$table.bootstrapTable('filterBy', par);
			}
			
			if (filterEstoqueAtivo) {
				let currentData = $table.bootstrapTable('getData');
				let filteredData = currentData.filter(function(row) {
					return parseFloat(row.qtdestoqueatual) > 0;
				});
				
				$table.bootstrapTable('load', filteredData);
			}

			$("#filter-departamento").html(getText({ iddepartamento: filterIdDepartamento }, "iddepartamento", labels.iddepartamento));
			$("#filter-setor").html(getText({ idsetor: filterIdSetor }, "idsetor", labels.idsetor));
			adjustHeaderScrollbarGutter();
	    }

		function adjustHeaderScrollbarGutter() {
		    if (!$table) return;
		
		    var $container = $table.closest('.fixed-table-container');
		    var body = $container.find('.fixed-table-body')[0];
		    if (!body) return;
		
		    var sbw = body.offsetWidth - body.clientWidth;
		    $container.find('.fixed-table-header').css('padding-right', (sbw > 0 ? sbw : 0) + 'px');
		}
		
	    function setCurrAtvRealizada(idwfatividaderealizada) {
	    	_idwfatividaderealizada = idwfatividaderealizada;
			var par = { idwfatividaderealizada: idwfatividaderealizada };
			$("#apply-atividaderealizada").html(getText(par, "idwfatividaderealizada", labels.idwfatividaderealizada));
	    }

		function applyAtvRealizada() {
			let allTableData = $table.bootstrapTable("getData");
			let data = $table.bootstrapTable('getSelections');
			console.log(data);
			for (var i = 0; i < data.length; i++) {
				for (var j = 0; j < allTableData.length; j++) {
					if (data[i].recid === allTableData[j].recid) {
						$table.bootstrapTable('updateRow', {
							index: j,
							row: {
								idwfatividaderealizada: _idwfatividaderealizada,
							}
						});
					}
				}
			}
			doSaveTemp();
			adjustHeaderScrollbarGutter();
		}

		function clearAtvRealizada() {
			let allTableData = $table.bootstrapTable("getData");
			let data = $table.bootstrapTable('getSelections');
			console.log(data);
			for (var i = 0; i < data.length; i++) {
				for (var j = 0; j < allTableData.length; j++) {
					if (data[i].recid === allTableData[j].recid) {
						$table.bootstrapTable('updateRow', {
							index: j,
							row: {
								idwfatividaderealizada: null,
							}
						});
					}
				}
			}
			doSaveTemp();
			adjustHeaderScrollbarGutter();
		}

	    function dropDownRender(value, row, index, fieldName) {
			return [
			    \'<div class="dropdown">\',
			      \'<button type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" class="btn btn-\' + (value ? \'success\' : \'info\') +  \' btn-lg btn-block dropdown-toggle">\',
					value ? getText(row, fieldName, labels[fieldName]) : "Selecione uma opÃ§Ã£o...",
				\'</button>\',
				\'<ul class="dropdown-menu list-group"  style="width: 100%;"><li>\',
					getDropDownList(index, fieldName, labels[fieldName]),
				\'</li></ul>\',
			    \'</div>\'
			].join("");
	    }

		Number.prototype.format = function(c, d, t) {
			var n = this, 
			    c = isNaN(c = Math.abs(c)) ? 2 : c, 
			    d = d == undefined ? "," : d, 
			    t = t == undefined ? "." : t, 
			    s = n < 0 ? "-" : "", 
			    i = String(parseInt(n = Math.abs(Number(n) || 0).toFixed(c))), 
			    j = (j = i.length) > 3 ? j % 3 : 0;
			   return s + (j ? i.substr(0, j) + t : "") + i.substr(j).replace(/(\\d{3})(?=\\d)/g, "$1" + t) + (c ? d + Math.abs(n - i).toFixed(c).slice(2) : "");
		};

		function realRender(value, row, index, fieldName, dc) {
			return value === null ? "-" : "R$ " + value.toFixed(2).replace(".", ",").replace(/(\\d)(?=(\\d{3})+\\,)/g, "$1.");
		}

	    function decimalRender(value, row, index, fieldName, dc) {
			return value === null ? "-" : Number(value).format(2);
		};

		function integerRender(value, row, index, fieldName) {
			return value === null ? "-" : Number(value).format(0);
		};

		function formatDate(value, row, index, fieldName) {
			return value === null ? "-" : value.length > 10 ? w2utils.formatDate(value.slice(0,10), 'dd/mm/yyyy') + ' ' + value.slice(10)  : w2utils.formatDate(value);
		}

		function getText(record, col, lab) {
			for (var i in lab) {
				if (lab[i].id == record[col]) {
					return lab[i].text;
				}
			}
			return "";
		}

		function NumberLoad(el, rowIndex, fieldName) {
			console.log('NumberLoad', el.value);
			$table.bootstrapTable("updateCell", { rowIndex: rowIndex, fieldName: fieldName, fieldValue: el.value });
		}		

	    function getDropDownList(index, fieldName, list) {
			var html = "";
			for(var i in list) {
				html += "<li class=\\"list-group-item\\" onclick=\\"setDropDown(" + [ index, "\'" + fieldName + "\'",  list[i].id].join() + ")\\\"><h4>" + list[i].text + "</h4></li>";
			}
			return html;
	    }
    </script>
  
